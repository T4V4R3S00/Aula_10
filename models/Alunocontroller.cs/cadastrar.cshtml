@model MeuPrimeiroMVC.Models.Aluno

@{
    ViewData["Title"] = "Cadastro de Aluno";
}

<div class="container mt-5" style="max-width: 600px;">
    <h2 class="mb-4">Cadastro de Aluno</h2>

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensagemSucesso"]
        </div>
    }

    <form asp-action="Cadastrar" method="post" class="shadow p-4 bg-white rounded border">
        
        <div class="mb-3 d-flex flex-column">
            <label asp-for="Nome" class="form-label fw-bold"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger mt-1 small"></span>
        </div>

        <div class="mb-3 d-flex flex-column">
            <label asp-for="Email" class="form-label fw-bold"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger mt-1 small"></span>
        </div>

        <div class="mb-3 d-flex flex-column">
            <label asp-for="RA" class="form-label fw-bold"></label>
            <input asp-for="RA" class="form-control" />
            <span asp-validation-for="RA" class="text-danger mt-1 small"></span>
        </div>

        <div class="mb-3 d-flex flex-column">
            <label asp-for="Curso" class="form-label fw-bold"></label>
            <input asp-for="Curso" class="form-control" />
            <span asp-validation-for="Curso" class="text-danger mt-1 small"></span>
        </div>

        <div class="mb-4 d-flex flex-column">
            <label asp-for="DataNascimento" class="form-label fw-bold"></label>
            <input asp-for="DataNascimento" class="form-control" />
            <span asp-validation-for="DataNascimento" class="text-danger mt-1 small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Cadastrar Aluno</button>
    </form>
</div>